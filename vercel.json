{
    "version": 2,
    "builds": [
        {
            "src": "css/**",
            "use": "@vercel/static"
        },
        {
            "src": "js/**",
            "use": "@vercel/static"
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        },
        {
            "src": "api/**/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "php/**/*.php",
            "use": "vercel-php@0.9.0"
        }
    ]
}

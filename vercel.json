{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "php/**/*.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
